# NhutCoder Team — Environment Variables for Cloudflare Pages
# Copy to .env.local for local development

# Site URL
NEXT_PUBLIC_SITE_URL=https://nhutcoder-team.pages.dev

# Cloudflare D1 (auto-injected by Pages at runtime — no env var needed)
# DB binding is configured in wrangler.toml + Cloudflare dashboard

# Cloudflare R2 (auto-injected by Pages at runtime)
# R2 binding is configured in wrangler.toml + Cloudflare dashboard

# R2 public URL (for serving uploaded images)
# Set this to your R2 custom domain or leave blank to use /api/images/ proxy
NEXT_PUBLIC_R2_PUBLIC_URL=

# Cloudflare API (for Drizzle migrations — NOT needed at runtime)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_ID=
CLOUDFLARE_API_TOKEN=

# GitHub (for projects data)
GITHUB_TOKEN=
GITHUB_USERNAME=nhut0902

# Contact form webhook (optional — Slack/Discord/Resend)
CONTACT_WEBHOOK_URL=

# Analytics (optional)
# CLOUDFLARE_ANALYTICS_TOKEN=
