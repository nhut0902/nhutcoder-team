{
  "name": "nhutcoder-team",
  "version": "1.0.0",
  "private": true,
  "description": "NhutCoder Team — Building the future with code and AI. Developer / Open Source / AI brand website.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npx opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "npx wrangler deploy",
    "cf:dev": "npx opennextjs-cloudflare build && npx wrangler dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node db/seed.js"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@marmoui/ui": "2.0.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.2",
    "geist": "^1.5.1",
    "lucide-react": "^0.469.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.112.0"
  }
}
